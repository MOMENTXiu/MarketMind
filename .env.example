APP_NAME=MarketMind
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS='["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]'
DATA_PATH=analysis/dataset.csv
OUTPUT_DIR=outputs
CHARTS_DIR=outputs/charts
REPORTS_DIR=outputs/reports
ASSOCIATION_MIN_SUPPORT=0.02
ASSOCIATION_MIN_CONFIDENCE=0.3
ASSOCIATION_MIN_LIFT=1.0
FORECAST_WEEKS=13
RIDGE_ALPHA=10.0
CLUSTER_N_CLUSTERS=4

DATABASE_URL=postgresql+psycopg://marketmind:marketmind_dev_password@localhost:5432/marketmind
TEST_DATABASE_URL=postgresql+psycopg://marketmind:marketmind_dev_password@localhost:5432/marketmind_test
DB_ECHO=false
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
TASK_QUEUE_BACKEND=redis
ANALYSIS_QUEUE_NAME=retail-analysis
ANALYSIS_EVENT_HEARTBEAT_MS=15000
ANALYSIS_EVENT_RETRY_MS=3000

OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_BUCKET=marketmind-dev
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=marketmind
OBJECT_STORAGE_SECRET_KEY=marketmind_dev_password
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_SECURE=false
OBJECT_STORAGE_PRESIGNED_URL_TTL_SECONDS=900
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# ── Admin Console ──────────────────────────────────────────────────────────
# These are read by scripts/setup-admin.sh, not by the backend.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_DISPLAY_NAME=Admin
ADMIN_CONSOLE_URL=http://localhost:5173/admin

# LLM Provider (for Admin Console settings display)
LLM_PROVIDER=
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30

# Bark Alert (for Admin Console alert push notifications)
BARK_ENABLED=false
BARK_SERVER_URL=
BARK_DEVICE_KEY=
BARK_DEFAULT_GROUP=
